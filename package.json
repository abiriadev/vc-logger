{
	"name": "package",
	"version": "0.0.0",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"build": "swc src -d dist --strip-leading-paths",
		"build:type": "tsc",
		"start": "node --enable-source-maps dist/index.js",
		"start:dev": "tsx --env-file .env ./src/index.ts",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@swc/cli": "^0.7.9",
		"@swc/core": "^1.15.8",
		"@types/node": "^25.0.5",
		"prettier": "^3.7.4",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"discord.js": "^14.25.1",
		"tslog": "^4.10.2"
	}
}
